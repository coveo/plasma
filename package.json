{
    "name": "root",
    "version": "59.7.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "changeset": "changeset",
        "changeset:version": "changeset version",
        "clean": "pnpm --recursive --parallel clean",
        "commit-cli": "cz",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "preinstall": "npx only-allow pnpm",
        "lint": "oxlint",
        "lintfix": "pnpm --recursive --parallel lintfix",
        "pnpm:devPreinstall": "pnpm turbo:login",
        "precommit": "lint-staged",
        "prepare": "husky",
        "reconstruct": "pnpm dlx rimraf packages/*/node_modules packages/*/.turbo node_modules && npm run setup && echo done",
        "release:pre:enter:next": "changeset pre enter next",
        "release:pre:exit": "changeset pre exit",
        "release:pre:publish:next": "changeset publish",
        "release:publish": "changeset publish",
        "setup": "pnpm install",
        "start": "turbo run build --filter=!storybook && pnpm --recursive --parallel start",
        "test": "turbo run test --concurrency=1",
        "turbo:login": "node scripts/turboLogin.js"
    },
    "devDependencies": {
        "@changesets/changelog-github": "0.5.1",
        "@changesets/cli": "2.29.6",
        "@commitlint/cli": "20.5.2",
        "@commitlint/config-conventional": "20.5.0",
        "@types/node": "24.12.2",
        "@typescript/native-preview": "7.0.0-dev.20260420.1",
        "aws-sdk": "2.1693.0",
        "commitizen": "4.3.1",
        "conventional-changelog-angular": "8.3.1",
        "cz-conventional-changelog": "3.3.0",
        "eslint": "9.39.4",
        "eslint-plugin-storybook": "10.3.5",
        "eslint-plugin-testing-library": "7.16.2",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "oxfmt": "0.51.0",
        "oxlint": "1.66.0",
        "oxlint-tsgolint": "0.23.0",
        "postcss": "8.5.14",
        "stylelint": "17.9.1",
        "stylelint-config-standard-scss": "17.0.0",
        "turbo": "2.9.6"
    },
    "lint-staged": {
        "**/*.{js,jsx,ts,tsx,mjs,json,md,yml,html}": [
            "oxfmt --write --no-error-on-unmatched-pattern"
        ],
        "**/*.{scss,css}": [
            "stylelint --fix",
            "oxfmt --write --no-error-on-unmatched-pattern"
        ]
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "browserslist": [
        "cover 90%",
        "last 1 versions",
        "IE 11",
        "not dead"
    ],
    "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
