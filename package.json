{
    "name": "root",
    "version": "59.8.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "changeset": "changeset",
        "changeset:version": "changeset version",
        "clean": "pnpm --recursive --parallel run clean",
        "fmt": "oxfmt",
        "fmt:check": "oxfmt --check",
        "preinstall": "npx only-allow pnpm",
        "lint": "oxlint",
        "lintfix": "pnpm --recursive --parallel lintfix",
        "pnpm:devPreinstall": "pnpm turbo:login",
        "precommit": "lint-staged",
        "prepare": "husky",
        "reconstruct": "pnpm dlx rimraf packages/*/node_modules packages/*/.turbo node_modules && npm run setup && echo done",
        "release:pre:enter:next": "changeset pre enter next",
        "release:pre:exit": "changeset pre exit",
        "release:pre:publish:next": "changeset publish",
        "release:publish": "changeset publish",
        "setup": "pnpm install",
        "start": "turbo run build --filter=!@coveord/plasma-storybook && pnpm --recursive --parallel start",
        "test": "turbo run test --concurrency=1",
        "turbo:login": "node scripts/turboLogin.js"
    },
    "devDependencies": {
        "@changesets/changelog-github": "0.7.0",
        "@changesets/cli": "2.31.1",
        "@changesets/get-github-info": "0.8.0",
        "@types/node": "24.13.3",
        "@typescript/native-preview": "7.0.0-dev.20260707.2",
        "aws-sdk": "2.1693.0",
        "eslint": "10.7.0",
        "eslint-plugin-storybook": "10.5.0",
        "eslint-plugin-testing-library": "7.16.2",
        "husky": "9.1.7",
        "lint-staged": "17.0.8",
        "oxfmt": "0.59.0",
        "oxlint": "1.74.0",
        "oxlint-tsgolint": "0.24.0",
        "postcss": "8.5.19",
        "stylelint": "17.14.0",
        "stylelint-config-standard-scss": "17.0.0",
        "turbo": "2.9.6"
    },
    "lint-staged": {
        "**/*.{js,jsx,ts,tsx,mjs,json,md,yml,html}": [
            "oxfmt --write --no-error-on-unmatched-pattern"
        ],
        "**/*.{scss,css}": [
            "stylelint --fix",
            "oxfmt --write --no-error-on-unmatched-pattern"
        ]
    },
    "browserslist": [
        "cover 90%",
        "last 1 versions",
        "IE 11",
        "not dead"
    ],
    "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
