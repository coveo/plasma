{
    "name": "root",
    "version": "59.1.1",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "clean": "pnpm --recursive --parallel clean",
        "commit-cli": "cz",
        "preinstall": "npx only-allow pnpm",
        "lintfix": "pnpm --recursive --parallel lintfix",
        "pnpm:devPreinstall": "pnpm turbo:login",
        "precommit": "lint-staged",
        "prepare": "husky",
        "reconstruct": "pnpm dlx rimraf packages/*/node_modules packages/*/.turbo node_modules && npm run setup && echo done",
        "setup": "pnpm install",
        "start": "turbo run build --filter=!storybook && pnpm --recursive --parallel start",
        "test": "turbo run test --concurrency=1",
        "turbo:login": "node scripts/turboLogin.mjs"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "lint-staged": {
        "**/package.json": [
            "sort-package-json"
        ],
        "**/*.{js,jsx,ts,tsx,mjs,json,md,yml,html}": [
            "prettier --write"
        ],
        "**/*.{scss,css}": [
            "stylelint --fix",
            "prettier --write"
        ]
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "browserslist": [
        "cover 90%",
        "last 1 versions",
        "IE 11",
        "not dead"
    ],
    "devDependencies": {
        "@commitlint/cli": "20.5.0",
        "@commitlint/config-conventional": "20.5.0",
        "@coveo/semantic-monorepo-tools": "2.7.1",
        "@types/node": "24.12.2",
        "@typescript/native-preview": "7.0.0-dev.20260420.1",
        "@vitest/eslint-plugin": "1.6.16",
        "aws-sdk": "2.1693.0",
        "commitizen": "4.3.1",
        "conventional-changelog-angular": "8.3.1",
        "cz-conventional-changelog": "3.3.0",
        "eslint": "9.39.4",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import-x": "4.16.2",
        "eslint-plugin-jsdoc": "62.9.0",
        "eslint-plugin-prefer-arrow": "1.2.3",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-react-refresh": "0.5.2",
        "eslint-plugin-storybook": "10.3.5",
        "eslint-plugin-testing-library": "7.16.2",
        "eslint-plugin-unused-imports": "4.4.1",
        "globals": "17.5.0",
        "husky": "9.1.7",
        "lint-staged": "16.4.0",
        "postcss": "8.5.10",
        "prettier": "3.8.3",
        "sort-package-json": "3.6.1",
        "stylelint": "17.8.0",
        "stylelint-config-standard-scss": "17.0.0",
        "turbo": "2.9.6",
        "typescript-eslint": "8.58.2"
    },
    "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
    "pnpm": {
        "peerDependencyRules": {
            "ignoreMissing": [
                "react-native"
            ]
        },
        "overrides": {
            "@babel/traverse": "^7.23.2",
            "nwsapi": "2.2.23"
        }
    }
}
