{
    "name": "root",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "build": "turbo run build",
        "clean": "pnpm --recursive --parallel clean",
        "commit-cli": "cz",
        "preinstall": "npx only-allow pnpm",
        "lintfix": "pnpm --recursive --parallel lintfix",
        "precommit": "lint-staged",
        "prepare": "husky",
        "reconstruct": "pnpm dlx rimraf packages/*/node_modules packages/*/.turbo node_modules && npm run setup && echo done",
        "setup": "pnpm install",
        "start": "turbo run build --filter=!@coveord/plasma-website && pnpm --recursive --parallel start",
        "test": "turbo run test --concurrency=1"
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "lint-staged": {
        "**/package.json": [
            "sort-package-json"
        ],
        "**/*.{js,jsx,ts,tsx,mjs,json,md,yml,html}": [
            "prettier --write"
        ],
        "**/*.{scss,css}": [
            "stylelint --fix",
            "prettier --write"
        ]
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "browserslist": [
        "cover 90%",
        "last 1 versions",
        "IE 11",
        "not dead"
    ],
    "devDependencies": {
        "@commitlint/cli": "19.8.1",
        "@commitlint/config-conventional": "19.8.1",
        "@coveo/semantic-monorepo-tools": "2.6.11",
        "@sindresorhus/slugify": "2.2.1",
        "@types/node": "22.16.5",
        "@vitest/eslint-plugin": "1.3.4",
        "aws-sdk": "2.1692.0",
        "chokidar": "4.0.3",
        "commitizen": "4.3.1",
        "conventional-changelog-angular": "8.0.0",
        "cz-conventional-changelog": "3.3.0",
        "eslint": "9.32.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-import-x": "4.16.1",
        "eslint-plugin-jsdoc": "50.8.0",
        "eslint-plugin-prefer-arrow": "1.2.3",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "5.2.0",
        "eslint-plugin-react-refresh": "0.4.20",
        "eslint-plugin-testing-library": "7.6.1",
        "eslint-plugin-unused-imports": "4.1.4",
        "globals": "16.3.0",
        "husky": "9.1.7",
        "lint-staged": "15.5.2",
        "mime-types": "2.1.35",
        "postcss": "8.5.6",
        "prettier": "3.6.2",
        "sort-package-json": "3.4.0",
        "stylelint": "16.22.0",
        "stylelint-config-standard-scss": "14.0.0",
        "turbo": "2.5.5",
        "typescript": "5.8.3",
        "typescript-eslint": "8.38.0",
        "underscore": "1.13.7",
        "walkdir": "0.4.1"
    },
    "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad",
    "pnpm": {
        "peerDependencyRules": {
            "ignoreMissing": [
                "react-native"
            ]
        },
        "overrides": {
            "@babel/traverse": "^7.23.2",
            "nwsapi": "2.2.21"
        },
        "patchedDependencies": {
            "@stencil/core": "patches/@stencil__core.patch"
        }
    }
}
