+export type OnChange = (value: string | undefined, ev: editor.IModelContentChangedEvent) => void;
+export type OnValidate = (markers: editor.IMarker[]) => void;
+export type EditorProps = {
+    defaultValue?: string;
+    defaultLanguage?: string;
+    defaultPath?: string;
+    value?: string;
+    language?: string;
+    path?: string;
+    theme?: Theme | string;
+    line?: number;
+    loading?: ReactNode;
+    options?: editor.IStandaloneEditorConstructionOptions;
+    overrideServices?: editor.IEditorOverrideServices;
+    saveViewState?: boolean;
+    keepCurrentModel?: boolean;
+    width?: number | string;
+    height?: number | string;
+    className?: string;
+    wrapperProps?: object;
+    beforeMount?: BeforeMount;
+    onMount?: OnMount;
+    onChange?: OnChange;
+    onValidate?: OnValidate;
+};
+
+declare function Editor(props: EditorProps): JSX.Element;
+export default Editor;
+
+export type { MonacoDiffEditor };
