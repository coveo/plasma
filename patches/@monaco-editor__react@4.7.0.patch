+    config(params: { paths?: { vs?: string }; 'vs/nls'?: { availableLanguages?: object }; monaco?: Monaco }): void;
+    __getMonacoInstance(): Monaco | null;
+};
+
+type MonacoDiffEditor = editor.IStandaloneDiffEditor;
