+    onMount?: DiffOnMount;
+};
+
+export declare function DiffEditor(props: DiffEditorProps): JSX.Element;
+export declare function useMonaco(): typeof monaco_editor | null;
+
+export type OnMount = (editor: editor.IStandaloneCodeEditor, monaco: Monaco) => void;
