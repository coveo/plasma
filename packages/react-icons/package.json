{
    "name": "@coveord/plasma-react-icons",
    "version": "59.4.3",
    "description": "Plasma iconography exposed as react components",
    "keywords": [
        "icons",
        "plasma",
        "react"
    ],
    "homepage": "https://github.com/coveo/plasma/packages/react-icons#readme",
    "bugs": {
        "url": "https://github.com/coveo/plasma/issues"
    },
    "license": "ISC",
    "author": "",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/coveo/plasma.git",
        "directory": "packages/react-icons"
    },
    "files": [
        "dist/*",
        "mock/index.js"
    ],
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./mock": {
            "types": "./dist/mock/index.d.ts",
            "import": "./dist/mock/index.js"
        },
        "./testing-library": {
            "types": "./dist/testing-library/index.d.ts",
            "import": "./dist/testing-library/index.js"
        },
        "./vite-plugin": {
            "types": "./dist/vite-plugin/index.d.ts",
            "import": "./dist/vite-plugin/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "pnpm generate && node ../../scripts/build.js",
        "clean": "rimraf dist",
        "generate": "node ./bin/index.js",
        "lintfix": "oxfmt --write && oxlint --fix",
        "prepublishOnly": "publint",
        "test": "pnpm generate && vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@swc/helpers": "0.5.21",
        "@tabler/icons-react": "3.41.1"
    },
    "devDependencies": {
        "@babel/types": "7.29.0",
        "@coveord/plasma-tokens": "workspace:*",
        "@svgr/core": "8.1.0",
        "@svgr/plugin-jsx": "8.1.0",
        "@swc/cli": "0.8.1",
        "@swc/core": "1.15.32",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@types/node": "24.12.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260420.1",
        "fs-extra": "11.3.4",
        "glob": "13.0.6",
        "jsdom": "29.1.0",
        "lodash.groupby": "4.6.0",
        "lodash.upperfirst": "4.3.1",
        "publint": "0.3.18",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "rimraf": "6.1.3",
        "tslib": "2.8.1",
        "vite": "8.0.11",
        "vitest": "4.1.5"
    },
    "peerDependencies": {
        "react": ">= 19.0.0 < 20.0.0",
        "react-dom": ">= 19.0.0 < 20.0.0"
    }
}
