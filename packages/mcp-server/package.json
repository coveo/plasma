{
    "name": "@coveord/plasma-mcp-server",
    "version": "59.4.0",
    "description": "MCP server for the Plasma design system — gives AI agents direct access to component documentation",
    "keywords": [
        "plasma",
        "mantine",
        "mcp",
        "ai",
        "coveo",
        "design-system"
    ],
    "bugs": {
        "url": "https://github.com/coveo/plasma/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/coveo/plasma.git",
        "directory": "packages/mcp-server"
    },
    "license": "Apache-2.0",
    "author": "Coveo",
    "type": "module",
    "bin": {
        "plasma-mcp-server": "./dist/server.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "pnpm clean && node lib/build.ts && tsc --project tsconfig.build.json",
        "clean": "rimraf dist",
        "lintfix": "../../node_modules/.bin/prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,html}\" && oxlint --fix",
        "test": "cross-env TZ=UTC vitest run",
        "test:watch": "cross-env TZ=UTC vitest"
    },
    "dependencies": {
        "@tmcp/adapter-valibot": "0.1.5",
        "@tmcp/transport-stdio": "0.4.2",
        "tmcp": "1.19.3",
        "valibot": "1.3.1"
    },
    "devDependencies": {
        "@coveord/plasma-llms": "workspace:*",
        "@types/node": "24.12.2",
        "cross-env": "10.1.0",
        "rimraf": "6.1.3",
        "typescript": "5.9.3",
        "vitest": "4.1.5"
    }
}
