{
    "name": "@coveord/plasma-mantine",
    "version": "60.0.1",
    "description": "A Plasma flavoured Mantine theme",
    "keywords": [
        "components",
        "coveo",
        "mantine",
        "plasma"
    ],
    "bugs": {
        "url": "https://github.com/coveo/plasma/issues"
    },
    "license": "Apache-2.0",
    "author": "Coveo",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/coveo/plasma.git",
        "directory": "packages/mantine"
    },
    "type": "module",
    "sideEffects": true,
    "exports": {
        ".": {
            "import": "./dist/index.js"
        },
        "./plasmantine": {
            "types": "./dist/theme.d.ts",
            "import": "./dist/theme.js"
        },
        "./core": {
            "types": "./dist/core.d.ts",
            "import": "./dist/core.js"
        },
        "./hooks": {
            "types": "./dist/hooks.d.ts",
            "import": "./dist/hooks.js"
        },
        "./form": {
            "types": "./dist/form.d.ts",
            "import": "./dist/form.js"
        },
        "./notifications": {
            "types": "./dist/notifications.d.ts",
            "import": "./dist/notifications.js"
        },
        "./components/*": {
            "types": "./dist/components/*/*.d.ts",
            "import": "./dist/components/*/*.js"
        },
        "./factory": {
            "types": "./dist/factory.d.ts",
            "import": "./dist/factory.js"
        },
        "./context": {
            "types": "./dist/context.d.ts",
            "import": "./dist/context.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "node ../../scripts/build.js",
        "clean": "rimraf dist",
        "generate:components:exports": "node --experimental-strip-types scripts/GenerateMantineComponentExports.ts",
        "lintfix": "oxfmt --write && oxlint --fix",
        "prepublishOnly": "publint",
        "start": "node ../../scripts/start.js",
        "test": "cross-env TZ=UTC vitest run",
        "test:watch": "cross-env TZ=UTC vitest"
    },
    "dependencies": {
        "@coveord/plasma-react-icons": "workspace:*",
        "@coveord/plasma-tokens": "workspace:*",
        "@dnd-kit/core": "6.3.1",
        "@dnd-kit/modifiers": "9.0.0",
        "@dnd-kit/sortable": "10.0.0",
        "@dnd-kit/utilities": "3.2.2",
        "@mantine/utils": "6.0.22",
        "@monaco-editor/react": "4.7.0",
        "@tanstack/react-table": "8.21.3",
        "@tanstack/table-core": "8.21.3",
        "clsx": "2.1.1",
        "dayjs": "1.11.20",
        "fast-deep-equal": "3.1.3",
        "lodash.defaultsdeep": "4.6.1",
        "monaco-editor": "0.55.1",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@mantine/carousel": "9.2.1",
        "@mantine/code-highlight": "9.2.1",
        "@mantine/core": "9.2.1",
        "@mantine/dates": "9.2.1",
        "@mantine/form": "9.2.1",
        "@mantine/hooks": "9.2.1",
        "@mantine/modals": "9.2.1",
        "@mantine/notifications": "9.2.1",
        "@testing-library/dom": "10.4.1",
        "@testing-library/jest-dom": "6.9.1",
        "@testing-library/react": "16.3.2",
        "@testing-library/user-event": "14.6.1",
        "@types/lodash.defaultsdeep": "4.6.9",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@typescript/native-preview": "7.0.0-dev.20260420.1",
        "cross-env": "10.1.0",
        "embla-carousel": "8.6.0",
        "embla-carousel-react": "8.6.0",
        "jsdom": "29.1.1",
        "postcss": "8.5.14",
        "postcss-preset-mantine": "^1.11.0",
        "postcss-simple-vars": "^7.0.1",
        "publint": "0.3.18",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "rimraf": "6.1.3",
        "vitest": "4.1.5"
    },
    "peerDependencies": {
        "@mantine/carousel": "^9.0.0",
        "@mantine/code-highlight": "^9.0.0",
        "@mantine/core": "^9.0.0",
        "@mantine/dates": "^9.0.0",
        "@mantine/form": "^9.0.0",
        "@mantine/hooks": "^9.0.0",
        "@mantine/modals": "^9.0.0",
        "@mantine/notifications": "^9.0.0",
        "embla-carousel-react": "^8.5.2",
        "react": ">= 19.2.0 < 20.0.0",
        "react-dom": ">= 19.2.0 < 20.0.0"
    },
    "peerDependenciesMeta": {
        "@mantine/carousel": {
            "optional": true
        },
        "@mantine/code-highlight": {
            "optional": true
        },
        "@mantine/dates": {
            "optional": true
        },
        "@mantine/form": {
            "optional": true
        },
        "@mantine/modals": {
            "optional": true
        },
        "@mantine/notifications": {
            "optional": true
        },
        "embla-carousel-react": {
            "optional": true
        }
    }
}
