{
    "name": "@coveord/plasma-tokens",
    "version": "60.0.0",
    "description": "Design tokens of the Plasma Design System",
    "homepage": "https://github.com/coveo/plasma/packages/tokens#readme",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/coveo/plasma.git",
        "directory": "packages/tokens"
    },
    "files": [
        "dist",
        "icons",
        "scss",
        "css"
    ],
    "type": "module",
    "sideEffects": [],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./scss": "./scss/index.scss",
        "./scss/*": "./scss/*",
        "./css/*": "./css/*",
        "./icons/*": "./icons/*",
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "rimraf dist && node ../../scripts/build.js",
        "lintfix": "oxfmt --write && oxlint --fix",
        "prepublishOnly": "publint",
        "tokens:build": "ts-node ./bin/build.ts --project ./tsconfig.bin.json && pnpm tokens:lint",
        "tokens:fetch": "ts-node -r dotenv-safe/config --project ./tsconfig.bin.json ./bin/fetch.ts",
        "tokens:lint": "oxfmt --write \"{src,scss,data}/*.{css,scss,ts,tsx,json}\""
    },
    "dependencies": {
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@types/chroma-js": "3.1.2",
        "@types/fs-extra": "11.0.4",
        "@types/lodash": "4.17.24",
        "@types/node": "24.13.2",
        "@typescript/native-preview": "7.0.0-dev.20260706.1",
        "chroma-js": "3.2.0",
        "commander": "15.0.0",
        "dotenv": "17.4.2",
        "dotenv-safe": "9.1.0",
        "figma-js": "1.16.0",
        "fs-extra": "11.3.6",
        "lint-staged": "16.4.0",
        "lodash": "4.18.1",
        "publint": "0.3.21",
        "rimraf": "6.1.3",
        "svgo": "4.0.1",
        "ts-node": "10.9.2"
    }
}
